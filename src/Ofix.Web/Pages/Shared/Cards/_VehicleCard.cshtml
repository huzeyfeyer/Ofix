@using Ofix.Localization
@using Microsoft.Extensions.Localization
@model Ofix.Web.Pages.Shared.Cards.VehicleCardViewModel
@inject IStringLocalizer<OfixResource> L

<article class="vehicle-card h-100 border rounded-3 overflow-hidden bg-white">
    <a href="@Model.DetailUrl" class="text-decoration-none text-reset d-block">
        <div class="vehicle-card-image-wrapper">
            <img src="@Model.ImageUrl" alt="@Model.Title" class="vehicle-card-image w-100" />
        </div>

        <div class="vehicle-card-content p-3">
            <h3 class="h5 mb-2 fw-bold">@Model.Title</h3>
            <div class="fs-4 fw-bold mb-2">@Model.PriceText</div>

            <div class="text-muted mb-3">
                @if (Model.Year.HasValue)
                {
                    <span>@Model.Year.Value</span>
                }
                @if (Model.Mileage.HasValue)
                {
                    <span> | @Model.Mileage.Value km</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.FuelTypeText))
                {
                    <span> | @Model.FuelTypeText</span>
                }
            </div>

            @if (Model.IsNew)
            {
                <span class="badge rounded-pill bg-warning text-dark mb-3">@L["VehicleCard:New"]</span>
            }

            <div class="border-top pt-2 text-muted small">
                <div>@L["VehicleCard:Dealer"]</div>
                <div>@Model.DealerName</div>
                <div>@Model.LocationText</div>
            </div>
        </div>
    </a>
</article>
