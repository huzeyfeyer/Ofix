@page
@using Ofix.Localization
@using Microsoft.Extensions.Localization
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@model Ofix.Web.Pages.SubModels.CreateModalModel
@inject IStringLocalizer<OfixResource> L

@{
    Layout = null;
}

<form method="post" asp-page="/SubModels/CreateModal">
    <abp-modal>
        <abp-modal-header title="@L["NewSubModel"].Value"></abp-modal-header>

        <abp-modal-body>

            <input type="hidden" id="SubModelLocalization_SelectBrand" value="@L["SelectBrand"].Value" />
            <input type="hidden" id="SubModelLocalization_SelectBrandFirst" value="@L["SelectBrandFirst"].Value" />
            <input type="hidden" id="SubModelLocalization_SelectModel" value="@L["SelectModel"].Value" />

            <abp-select asp-for="BrandId"
                        asp-items="Model.Brands"
                        label="Brand">
            </abp-select>

            <abp-select asp-for="SubModel.ModelId"
                        asp-items="Model.Models"
                        label="Model">
            </abp-select>

            <abp-input asp-for="SubModel.Name"></abp-input>
            <abp-input asp-for="SubModel.OrderNo"></abp-input>
            <abp-select asp-for="SubModel.ListingStatus"></abp-select>
        </abp-modal-body>

        <abp-modal-footer buttons="@(AbpModalButtons.Cancel | AbpModalButtons.Save)">
        </abp-modal-footer>
    </abp-modal>
</form>